<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="main.controllers.PassSlipIssuanceController"
    prefWidth="1100" prefHeight="760">

    <!-- ═══════════════════════════ SIDEBAR ═══════════════════════════ -->
    <left>
        <VBox prefWidth="160" minWidth="160"
              style="-fx-background-color:#8B0000;">

            <!-- Brand -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-padding:22 16 18 16; -fx-background-color:#7A0000;">
                <Label text="⬡"
                       style="-fx-text-fill:white; -fx-font-size:24px;"/>
                <VBox spacing="1">
                    <Label text="Pass Slip"
                           style="-fx-text-fill:white; -fx-font-size:15px; -fx-font-weight:bold;"/>
                    <Label text="Issuance System"
                           style="-fx-text-fill:rgba(255,255,255,0.55); -fx-font-size:10px;"/>
                </VBox>
            </HBox>

            <!-- Nav -->
            <VBox spacing="2" VBox.vgrow="ALWAYS"
                  style="-fx-padding:14 10 14 10;">
                <Button fx:id="btnDashboard"  text="  Dashboard"          maxWidth="Infinity" onAction="#handleNavDashboard"
                        style="-fx-background-color:transparent; -fx-text-fill:rgba(255,255,255,0.72); -fx-alignment:CENTER_LEFT; -fx-font-size:13px; -fx-padding:9 14; -fx-cursor:hand; -fx-background-radius:7;"/>
                <Button fx:id="btnPassSlip"   text="  Pass Slip Issuance" maxWidth="Infinity" onAction="#handleNavPassSlip"
                        style="-fx-background-color:rgba(255,255,255,0.20); -fx-text-fill:white; -fx-font-weight:bold; -fx-alignment:CENTER_LEFT; -fx-font-size:13px; -fx-padding:9 14; -fx-cursor:hand; -fx-background-radius:7;"/>
                <Button fx:id="btnVisitor"    text="  Visitor Module"     maxWidth="Infinity" onAction="#handleNavVisitor"
                        style="-fx-background-color:transparent; -fx-text-fill:rgba(255,255,255,0.72); -fx-alignment:CENTER_LEFT; -fx-font-size:13px; -fx-padding:9 14; -fx-cursor:hand; -fx-background-radius:7;"/>
                <Button fx:id="btnReports"    text="  Reports"            maxWidth="Infinity" onAction="#handleNavReports"
                        style="-fx-background-color:transparent; -fx-text-fill:rgba(255,255,255,0.72); -fx-alignment:CENTER_LEFT; -fx-font-size:13px; -fx-padding:9 14; -fx-cursor:hand; -fx-background-radius:7;"/>
                <Button fx:id="btnUserMgmt"   text="  User Management"    maxWidth="Infinity" onAction="#handleNavUserMgmt"
                        style="-fx-background-color:transparent; -fx-text-fill:rgba(255,255,255,0.72); -fx-alignment:CENTER_LEFT; -fx-font-size:13px; -fx-padding:9 14; -fx-cursor:hand; -fx-background-radius:7;"/>
            </VBox>

            <!-- Footer -->
            <VBox spacing="8"
                  style="-fx-padding:12 12 18 12; -fx-background-color:rgba(0,0,0,0.18);">
                <VBox spacing="1"
                      style="-fx-padding:7 10; -fx-background-color:rgba(255,255,255,0.09); -fx-background-radius:6;">
                    <Label fx:id="lblAdminName" text="Admin"
                           style="-fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold;"/>
                    <Label fx:id="lblAdminRole" text="Admin"
                           style="-fx-text-fill:rgba(255,255,255,0.50); -fx-font-size:11px;"/>
                </VBox>
                <Button text="↪  Logout" maxWidth="Infinity" onAction="#handleLogout"
                        style="-fx-background-color:rgba(255,255,255,0.10); -fx-text-fill:rgba(255,255,255,0.85); -fx-font-size:12px; -fx-padding:8 12; -fx-cursor:hand; -fx-background-radius:6; -fx-alignment:CENTER_LEFT;"/>
            </VBox>
        </VBox>
    </left>

    <!-- ═══════════════════════════ MAIN ═══════════════════════════ -->
    <center>
        <VBox spacing="18"
              style="-fx-background-color:#F2F2F2; -fx-padding:0 20 20 20;">

            <!-- Top Bar -->
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-padding:16 4 8 4;">
                <VBox HBox.hgrow="ALWAYS" spacing="2">
                    <Label text="Pass Slip Issuance"
                           style="-fx-text-fill:#8B0000; -fx-font-size:22px; -fx-font-weight:bold;"/>
                    <Label text="Approved pass slips ready for download"
                           style="-fx-text-fill:#888; -fx-font-size:12px;"/>
                </VBox>
                <Button text="🔔" onAction="#handleNotifications"
                        style="-fx-background-color:transparent; -fx-font-size:18px; -fx-padding:4 8; -fx-cursor:hand; -fx-background-radius:20;"/>
            </HBox>

            <!-- ── Stat Cards ── -->
            <HBox spacing="14">
                <!-- Total Approved -->
                <VBox spacing="6" HBox.hgrow="ALWAYS"
                      style="-fx-background-color:white; -fx-background-radius:10; -fx-border-color:#E5E5E5; -fx-border-radius:10; -fx-border-width:1; -fx-padding:16 20; -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),4,0,0,2);">
                    <Label text="Total Approved"
                           style="-fx-text-fill:#999; -fx-font-size:12px;"/>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label fx:id="lblTotalApproved" text="0"
                               style="-fx-font-size:30px; -fx-font-weight:bold; -fx-text-fill:#2EAA5A;"/>
                        <Label text="✔"
                               style="-fx-font-size:22px; -fx-text-fill:#2EAA5A;"/>
                    </HBox>
                </VBox>
                <!-- Today's Approved -->
                <VBox spacing="6" HBox.hgrow="ALWAYS"
                      style="-fx-background-color:white; -fx-background-radius:10; -fx-border-color:#E5E5E5; -fx-border-radius:10; -fx-border-width:1; -fx-padding:16 20; -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),4,0,0,2);">
                    <Label text="Today's Approved"
                           style="-fx-text-fill:#999; -fx-font-size:12px;"/>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label fx:id="lblTodayApproved" text="0"
                               style="-fx-font-size:30px; -fx-font-weight:bold; -fx-text-fill:#E6A817;"/>
                        <Label text="📅"
                               style="-fx-font-size:20px;"/>
                    </HBox>
                </VBox>
                <!-- Downloaded -->
                <VBox spacing="6" HBox.hgrow="ALWAYS"
                      style="-fx-background-color:white; -fx-background-radius:10; -fx-border-color:#E5E5E5; -fx-border-radius:10; -fx-border-width:1; -fx-padding:16 20; -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),4,0,0,2);">
                    <Label text="Downloaded"
                           style="-fx-text-fill:#999; -fx-font-size:12px;"/>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label fx:id="lblDownloaded" text="0"
                               style="-fx-font-size:30px; -fx-font-weight:bold; -fx-text-fill:#1565C0;"/>
                        <Label text="⬇"
                               style="-fx-font-size:22px; -fx-text-fill:#1565C0;"/>
                    </HBox>
                </VBox>
                <!-- Printed -->
                <VBox spacing="6" HBox.hgrow="ALWAYS"
                      style="-fx-background-color:white; -fx-background-radius:10; -fx-border-color:#E5E5E5; -fx-border-radius:10; -fx-border-width:1; -fx-padding:16 20; -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),4,0,0,2);">
                    <Label text="Printed"
                           style="-fx-text-fill:#999; -fx-font-size:12px;"/>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label fx:id="lblPrinted" text="0"
                               style="-fx-font-size:30px; -fx-font-weight:bold; -fx-text-fill:#E67E22;"/>
                        <Label text="🖨"
                               style="-fx-font-size:20px;"/>
                    </HBox>
                </VBox>
            </HBox>

            <!-- ── Table Card ── -->
            <VBox spacing="12" VBox.vgrow="ALWAYS"
                  style="-fx-background-color:white; -fx-background-radius:10; -fx-border-color:#E5E5E5; -fx-border-radius:10; -fx-border-width:1; -fx-padding:16; -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),4,0,0,2);">

                <!-- Table Header -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <VBox HBox.hgrow="ALWAYS" spacing="2">
                        <Label text="Approved Pass Slip Requests"
                               style="-fx-text-fill:#333; -fx-font-size:14px; -fx-font-weight:bold;"/>
                        <Label fx:id="lblApprovedCount" text="0 approved requests"
                               style="-fx-text-fill:#999; -fx-font-size:12px;"/>
                    </VBox>
                    <Button text="⬇  Download All" onAction="#handleDownloadAll"
                            style="-fx-background-color:#2EAA5A; -fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold; -fx-padding:9 18; -fx-cursor:hand; -fx-background-radius:7;"/>
                </HBox>

                <!-- Search + Filter -->
                <HBox spacing="8">
                    <TextField fx:id="txtSearch"
                               promptText="Search by name, ID, or department..."
                               onKeyReleased="#handleSearch"
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-color:#F8F8F8; -fx-border-color:#DEDEDE; -fx-border-radius:6; -fx-background-radius:6; -fx-padding:7 12; -fx-font-size:13px;"/>
                    <ComboBox fx:id="cmbFilter" prefWidth="150"
                              onAction="#handleFilter"
                              style="-fx-background-color:#F8F8F8; -fx-border-color:#DEDEDE; -fx-border-radius:6; -fx-background-radius:6; -fx-font-size:13px;"/>
                </HBox>

                <!-- TableView -->
                <TableView fx:id="tblSlips" VBox.vgrow="ALWAYS"
                           style="-fx-background-color:transparent; -fx-border-color:transparent;">
                    <columns>
                        <TableColumn fx:id="colId"         text="Pass Slip ID"  prefWidth="95"/>
                        <TableColumn fx:id="colName"       text="Name"          prefWidth="95"/>
                        <TableColumn fx:id="colDept"       text="Department"    prefWidth="110"/>
                        <TableColumn fx:id="colPurpose"    text="Purpose"       prefWidth="120"/>
                        <TableColumn fx:id="colTimeOut"    text="Time Out"      prefWidth="80"/>
                        <TableColumn fx:id="colTimeIn"     text="Time In"       prefWidth="80"/>
                        <TableColumn fx:id="colDate"       text="Date"          prefWidth="90"/>
                        <TableColumn fx:id="colApprovedBy" text="Approved By"   prefWidth="100"/>
                        <TableColumn fx:id="colActions"    text="Actions"       prefWidth="130"/>
                    </columns>
                    <placeholder>
                        <Label text="No approved pass slips found."
                               style="-fx-text-fill:#AAA; -fx-font-size:13px;"/>
                    </placeholder>
                </TableView>
            </VBox>
        </VBox>
    </center>
</BorderPane>
