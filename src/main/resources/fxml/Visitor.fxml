<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="main.controllers.VisitorController"
        prefWidth="1100" prefHeight="760"
        style="-fx-background-color: #f9fafb;">

    <!-- ===== SIDEBAR ===== -->
    <left>
        <VBox prefWidth="160" minWidth="160"
              style="-fx-background-color: #8B0000;">

            <!-- Logo -->
            <VBox style="-fx-padding: 14 12 14 12; -fx-border-color: rgba(255,255,255,0.15); -fx-border-width: 0 0 1 0;">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="🛡" style="-fx-text-fill: white; -fx-font-size: 18px;"/>
                    <VBox>
                        <Label text="Pass Slip" style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                        <Label text="Issuance System" style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-size: 10px;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Nav Items -->
            <VBox VBox.vgrow="ALWAYS" style="-fx-padding: 6 0 0 0;">
                <Button text="  ⊞  Dashboard" maxWidth="Infinity" onAction="#handleNavDashboard"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 12.5px; -fx-alignment: CENTER_LEFT; -fx-padding: 10 12 10 12; -fx-border-width: 0; -fx-cursor: hand;"/>
                <Button text="  📋  Pass Slip Issuance" maxWidth="Infinity" onAction="#handleNavPassSlip"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 12.5px; -fx-alignment: CENTER_LEFT; -fx-padding: 10 12 10 12; -fx-border-width: 0; -fx-cursor: hand;"/>
                <Button text="  👤  Visitor Module" maxWidth="Infinity" onAction="#handleNavVisitor"
                        style="-fx-background-color: rgba(255,255,255,0.18); -fx-text-fill: white; -fx-font-size: 12.5px; -fx-alignment: CENTER_LEFT; -fx-padding: 10 12 10 12; -fx-border-width: 0; -fx-cursor: hand;"/>
                <Button text="  📊  Reports" maxWidth="Infinity" onAction="#handleNavReports"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 12.5px; -fx-alignment: CENTER_LEFT; -fx-padding: 10 12 10 12; -fx-border-width: 0; -fx-cursor: hand;"/>
                <Button text="  👥  User Management" maxWidth="Infinity" onAction="#handleNavUserMgmt"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 12.5px; -fx-alignment: CENTER_LEFT; -fx-padding: 10 12 10 12; -fx-border-width: 0; -fx-cursor: hand;"/>
            </VBox>

            <!-- Footer -->
            <VBox style="-fx-padding: 12 12 12 12; -fx-border-color: rgba(255,255,255,0.15); -fx-border-width: 1 0 0 0;">
                <Label fx:id="lblAdminName" text="Admin" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                <Label fx:id="lblAdminRole" text="Admin" style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 11px;"/>
                <Button text="↪  Logout" maxWidth="Infinity" onAction="#handleLogout"
                        style="-fx-background-color: rgba(255,255,255,0.12); -fx-text-fill: white; -fx-font-size: 12px; -fx-padding: 6 10 6 10; -fx-background-radius: 6; -fx-border-width: 0; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>
            </VBox>

        </VBox>
    </left>

    <!-- ===== MAIN CONTENT ===== -->
    <center>
        <VBox style="-fx-background-color: white;">

            <!-- Top Bar -->
            <HBox alignment="CENTER_LEFT"
                  style="-fx-padding: 14 20 12 20; -fx-border-color: #e8e8e8; -fx-border-width: 0 0 1 0; -fx-background-color: white;">
                <VBox HBox.hgrow="ALWAYS">
                    <Label text="Visitor Module" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;"/>
                    <Label text="Manage visitor access and requests" style="-fx-font-size: 12px; -fx-text-fill: #888;"/>
                </VBox>
                <Label text="🔔" style="-fx-font-size: 18px; -fx-text-fill: #888;"/>
            </HBox>

            <!-- Stat Cards -->
            <HBox spacing="12" style="-fx-padding: 14 20 0 20; -fx-background-color: white;">

                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #f8f8f8; -fx-background-radius: 10; -fx-padding: 12 14 12 14; -fx-border-color: #ececec; -fx-border-radius: 10; -fx-border-width: 1;">
                    <HBox alignment="CENTER_LEFT">
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="Pending Requests" style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
                            <Label fx:id="lblPending" text="0" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;"/>
                        </VBox>
                        <Label text="⏳" style="-fx-font-size: 22px; -fx-text-fill: #E6A817;"/>
                    </HBox>
                </VBox>

                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #f8f8f8; -fx-background-radius: 10; -fx-padding: 12 14 12 14; -fx-border-color: #ececec; -fx-border-radius: 10; -fx-border-width: 1;">
                    <HBox alignment="CENTER_LEFT">
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="Approved Requests" style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
                            <Label fx:id="lblApproved" text="0" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1D9E75;"/>
                        </VBox>
                        <Label text="✅" style="-fx-font-size: 22px; -fx-text-fill: #1D9E75;"/>
                    </HBox>
                </VBox>

                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #f8f8f8; -fx-background-radius: 10; -fx-padding: 12 14 12 14; -fx-border-color: #ececec; -fx-border-radius: 10; -fx-border-width: 1;">
                    <HBox alignment="CENTER_LEFT">
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="Rejected Requests" style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
                            <Label fx:id="lblRejected" text="0" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #E74C3C;"/>
                        </VBox>
                        <Label text="❌" style="-fx-font-size: 22px; -fx-text-fill: #E74C3C;"/>
                    </HBox>
                </VBox>

                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #f8f8f8; -fx-background-radius: 10; -fx-padding: 12 14 12 14; -fx-border-color: #ececec; -fx-border-radius: 10; -fx-border-width: 1;">
                    <HBox alignment="CENTER_LEFT">
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="Active Visitors Today" style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
                            <Label fx:id="lblActive" text="0" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #185FA5;"/>
                        </VBox>
                        <Label text="👤" style="-fx-font-size: 22px; -fx-text-fill: #185FA5;"/>
                    </HBox>
                </VBox>

            </HBox>

            <!-- Table Card -->
            <VBox spacing="10" VBox.vgrow="ALWAYS"
                  style="-fx-padding: 14 20 20 20; -fx-background-color: white;">

                <VBox spacing="10" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: #f8f8f8; -fx-background-radius: 10; -fx-padding: 14 14 14 14; -fx-border-color: #ececec; -fx-border-radius: 10; -fx-border-width: 1;">

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Visitor Requests" HBox.hgrow="ALWAYS"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;"/>
                        <Button text="+ New Visitor Request"
                                onAction="#handleNewVisitor"
                                style="-fx-background-color: #8B0000; -fx-text-fill: white;
                                       -fx-font-size: 12px; -fx-padding: 6 14 6 14;
                                       -fx-background-radius: 20; -fx-border-width: 0; -fx-cursor: hand;"/>
                    </HBox>

                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <TextField fx:id="txtSearch"
                                   promptText="🔍  Search by name, ID, or company..."
                                   onKeyReleased="#handleSearch"
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-background-color: white; -fx-border-color: #ddd;
                                          -fx-border-radius: 20; -fx-background-radius: 20;
                                          -fx-padding: 7 12 7 12; -fx-font-size: 12.5px;"/>
                        <ComboBox fx:id="cmbFilter" prefWidth="110"
                                  onAction="#handleFilter"
                                  style="-fx-background-radius: 20; -fx-border-radius: 20;
                                         -fx-border-color: #ddd; -fx-background-color: white;
                                         -fx-font-size: 12.5px;"/>
                    </HBox>

                    <TableView fx:id="tblVisitors" VBox.vgrow="ALWAYS" minHeight="300"
                               style="-fx-background-color: white; -fx-border-color: #e8e8e8; -fx-table-cell-border-color: #f0f0f0;">
                        <columns>
                            <TableColumn fx:id="colId"      text="Request ID"    prefWidth="90"/>
                            <TableColumn fx:id="colName"    text="Visitor Name"  prefWidth="110"/>
                            <TableColumn fx:id="colCompany" text="Company"       prefWidth="120"/>
                            <TableColumn fx:id="colPurpose" text="Purpose"       prefWidth="120"/>
                            <TableColumn fx:id="colTimeOut" text="Time Out"      prefWidth="80"/>
                            <TableColumn fx:id="colTimeIn"  text="Time In"       prefWidth="80"/>
                            <TableColumn fx:id="colHost"    text="Host Employee" prefWidth="110"/>
                            <TableColumn fx:id="colStatus"  text="Status"        prefWidth="90"/>
                            <TableColumn fx:id="colActions" text="Actions"       prefWidth="100"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                        <placeholder>
                            <Label text="No visitor requests found."
                                   style="-fx-text-fill: #aaa; -fx-font-size: 12px;"/>
                        </placeholder>
                    </TableView>

                </VBox>
            </VBox>

        </VBox>
    </center>

</BorderPane>