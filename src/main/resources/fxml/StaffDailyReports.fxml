<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    prefWidth="1100" prefHeight="760">

    <!-- ═══════════════════════════ SIDEBAR ═══════════════════════════ -->
    <left>
        <VBox prefWidth="160" minWidth="160"
              style="-fx-background-color:#8B0000;">

            <!-- Brand -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-padding:22 16 18 16; -fx-background-color:#7A0000;">
                <Label text="⬡"
                       style="-fx-text-fill:white; -fx-font-size:24px;"/>
                <VBox spacing="1">
                    <Label text="Pass Slip"
                           style="-fx-text-fill:white; -fx-font-size:15px; -fx-font-weight:bold;"/>
                    <Label text="Issuance System"
                           style="-fx-text-fill:rgba(255,255,255,0.55); -fx-font-size:10px;"/>
                </VBox>
            </HBox>

            <!-- Nav -->
            <VBox spacing="2" VBox.vgrow="ALWAYS"
                  style="-fx-padding:14 10 14 10;">
                <Button fx:id="btnDashboard" text="  Dashboard" maxWidth="Infinity"
                        style="-fx-background-color:transparent; -fx-text-fill:rgba(255,255,255,0.72); -fx-alignment:CENTER_LEFT; -fx-font-size:13px; -fx-padding:9 14; -fx-cursor:hand; -fx-background-radius:7; -fx-border-width:0;"/>
                <Button fx:id="btnPassSlip" text="  Pass Slip Issuance" maxWidth="Infinity"
                        style="-fx-background-color:transparent; -fx-text-fill:rgba(255,255,255,0.72); -fx-alignment:CENTER_LEFT; -fx-font-size:13px; -fx-padding:9 14; -fx-cursor:hand; -fx-background-radius:7; -fx-border-width:0;"/>
                <Button fx:id="btnVisitor" text="  Visitor Module" maxWidth="Infinity"
                        style="-fx-background-color:transparent; -fx-text-fill:rgba(255,255,255,0.72); -fx-alignment:CENTER_LEFT; -fx-font-size:13px; -fx-padding:9 14; -fx-cursor:hand; -fx-background-radius:7; -fx-border-width:0;"/>
                <Button fx:id="btnReports" text="  Reports" maxWidth="Infinity"
                        style="-fx-background-color:rgba(255,255,255,0.20); -fx-text-fill:white; -fx-font-weight:bold; -fx-alignment:CENTER_LEFT; -fx-font-size:13px; -fx-padding:9 14; -fx-cursor:hand; -fx-background-radius:7; -fx-border-width:0;"/>
            </VBox>

            <!-- Footer -->
            <VBox spacing="8"
                  style="-fx-padding:12 12 18 12; -fx-background-color:rgba(0,0,0,0.18);">
                <VBox spacing="1"
                      style="-fx-padding:7 10; -fx-background-color:rgba(255,255,255,0.09); -fx-background-radius:6;">
                    <Label fx:id="lblStaffName" text="Staff"
                           style="-fx-text-fill:white; -fx-font-size:13px; -fx-font-weight:bold;"/>
                    <Label fx:id="lblStaffRole" text="Staff"
                           style="-fx-text-fill:rgba(255,255,255,0.50); -fx-font-size:11px;"/>
                </VBox>
                <Button fx:id="btnLogout" text="↪  Logout" maxWidth="Infinity"
                        style="-fx-background-color:rgba(255,255,255,0.10); -fx-text-fill:rgba(255,255,255,0.85); -fx-font-size:12px; -fx-padding:8 12; -fx-cursor:hand; -fx-background-radius:6; -fx-alignment:CENTER_LEFT; -fx-border-width:0;"/>
            </VBox>
        </VBox>
    </left>

    <!-- ═══════════════════════════ MAIN ═══════════════════════════ -->
    <center>
        <VBox style="-fx-background-color:#F2F2F2;">

            <!-- Top Bar -->
            <HBox alignment="CENTER_LEFT"
                  style="-fx-padding:16 20 8 20;">
                <VBox HBox.hgrow="ALWAYS" spacing="2">
                    <Label text="Reports"
                           style="-fx-text-fill:#8B0000; -fx-font-size:22px; -fx-font-weight:bold;"/>
                    <Label text="View daily and monthly activity logs"
                           style="-fx-text-fill:#888; -fx-font-size:12px;"/>
                </VBox>
                <Button text="🔔"
                        style="-fx-background-color:transparent; -fx-font-size:18px; -fx-padding:4 8; -fx-cursor:hand; -fx-background-radius:20; -fx-border-width:0;"/>
            </HBox>

            <!-- Stat Cards -->
            <HBox spacing="14" style="-fx-padding:0 20 14 20;">
                <!-- Total This Month -->
                <VBox spacing="6" HBox.hgrow="ALWAYS"
                      style="-fx-background-color:white; -fx-background-radius:10; -fx-border-color:#E5E5E5; -fx-border-radius:10; -fx-border-width:1; -fx-padding:16 20; -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),4,0,0,2);">
                    <Label text="Total This Month" style="-fx-text-fill:#999; -fx-font-size:12px;"/>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label fx:id="lblTotalMonth" text="0"
                               style="-fx-font-size:30px; -fx-font-weight:bold; -fx-text-fill:#1a1a1a;"/>
                        <Label text="📄" style="-fx-font-size:22px; -fx-text-fill:#ccc;"/>
                    </HBox>
                </VBox>
                <!-- Approved Rate -->
                <VBox spacing="6" HBox.hgrow="ALWAYS"
                      style="-fx-background-color:white; -fx-background-radius:10; -fx-border-color:#E5E5E5; -fx-border-radius:10; -fx-border-width:1; -fx-padding:16 20; -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),4,0,0,2);">
                    <Label text="Approved Rate" style="-fx-text-fill:#999; -fx-font-size:12px;"/>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label fx:id="lblApprovedRate" text="0%"
                               style="-fx-font-size:30px; -fx-font-weight:bold; -fx-text-fill:#1D9E75;"/>
                        <Label text="📈" style="-fx-font-size:22px; -fx-text-fill:#1D9E75;"/>
                    </HBox>
                </VBox>
                <!-- Avg Duration -->
                <VBox spacing="6" HBox.hgrow="ALWAYS"
                      style="-fx-background-color:white; -fx-background-radius:10; -fx-border-color:#E5E5E5; -fx-border-radius:10; -fx-border-width:1; -fx-padding:16 20; -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),4,0,0,2);">
                    <Label text="Avg Duration" style="-fx-text-fill:#999; -fx-font-size:12px;"/>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label fx:id="lblAvgDuration" text="—"
                               style="-fx-font-size:30px; -fx-font-weight:bold; -fx-text-fill:#185FA5;"/>
                        <Label text="🕐" style="-fx-font-size:22px; -fx-text-fill:#185FA5;"/>
                    </HBox>
                </VBox>
                <!-- Total Visitors -->
                <VBox spacing="6" HBox.hgrow="ALWAYS"
                      style="-fx-background-color:white; -fx-background-radius:10; -fx-border-color:#E5E5E5; -fx-border-radius:10; -fx-border-width:1; -fx-padding:16 20; -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),4,0,0,2);">
                    <Label text="Total Visitors" style="-fx-text-fill:#999; -fx-font-size:12px;"/>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label fx:id="lblTotalVisitors" text="0"
                               style="-fx-font-size:30px; -fx-font-weight:bold; -fx-text-fill:#BA7517;"/>
                        <Label text="👥" style="-fx-font-size:22px; -fx-text-fill:#BA7517;"/>
                    </HBox>
                </VBox>
            </HBox>

            <!-- Tabs + Export Button -->
            <HBox alignment="CENTER_LEFT" style="-fx-padding:0 20 10 20;">
                <HBox spacing="6" HBox.hgrow="ALWAYS">
                    <ToggleButton fx:id="btnDailyLogs" text="Daily Logs" selected="true"
                                  style="-fx-background-color:#8B0000; -fx-text-fill:white; -fx-font-size:13px; -fx-padding:6 18 6 18; -fx-background-radius:20; -fx-border-width:0; -fx-cursor:hand;"/>
                    <ToggleButton fx:id="btnMonthlyLogs" text="Monthly Logs"
                                  style="-fx-background-color:white; -fx-text-fill:#555; -fx-font-size:13px; -fx-padding:6 18 6 18; -fx-background-radius:20; -fx-border-color:#ddd; -fx-border-radius:20; -fx-border-width:1; -fx-cursor:hand;"/>
                </HBox>
                <Button fx:id="btnExportReport" text="⬇  Export Report"
                        style="-fx-background-color:#1D9E75; -fx-text-fill:white; -fx-font-size:12.5px; -fx-padding:7 16 7 16; -fx-background-radius:20; -fx-border-width:0; -fx-cursor:hand;"/>
            </HBox>

            <!-- ===== DAILY LOGS SECTION ===== -->
            <VBox fx:id="dailySection" VBox.vgrow="ALWAYS" spacing="8"
                  style="-fx-padding:0 20 20 20;">

                <!-- Search + Filter -->
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <TextField fx:id="searchField"
                               promptText="🔍  Search by name, ID, or department..."
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-color:white; -fx-border-color:#ddd; -fx-border-radius:20; -fx-background-radius:20; -fx-padding:7 12 7 12; -fx-font-size:12.5px;"/>
                    <ComboBox fx:id="filterStatus" promptText="Filter"
                              style="-fx-background-radius:20; -fx-border-radius:20; -fx-border-color:#ddd; -fx-background-color:white; -fx-font-size:12.5px; -fx-pref-width:110px;"/>
                </HBox>

                <!-- Daily Table -->
                <TableView fx:id="dailyTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color:white; -fx-border-color:#e8e8e8; -fx-table-cell-border-color:#f0f0f0;">
                    <columns>
                        <TableColumn fx:id="colRequestId"  text="Request ID"    prefWidth="90"/>
                        <TableColumn fx:id="colDate"       text="Date"          prefWidth="90"/>
                        <TableColumn fx:id="colEmpName"    text="Employee Name" prefWidth="120"/>
                        <TableColumn fx:id="colDepartment" text="Department"    prefWidth="110"/>
                        <TableColumn fx:id="colPurpose"    text="Purpose"       prefWidth="130"/>
                        <TableColumn fx:id="colTimeOut"    text="Time Out"      prefWidth="80"/>
                        <TableColumn fx:id="colTimeIn"     text="Time In"       prefWidth="80"/>
                        <TableColumn fx:id="colDuration"   text="Duration"      prefWidth="70"/>
                        <TableColumn fx:id="colStatus"     text="Status"        prefWidth="90"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                    <placeholder>
                        <Label text="No report records found."
                               style="-fx-text-fill:#AAA; -fx-font-size:13px;"/>
                    </placeholder>
                </TableView>
            </VBox>

            <!-- ===== MONTHLY LOGS SECTION ===== -->
            <VBox fx:id="monthlySection" VBox.vgrow="ALWAYS"
                  visible="false" managed="false"
                  style="-fx-padding:0 20 20 20;">

                <!-- Monthly Table -->
                <TableView fx:id="monthlyTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color:white; -fx-border-color:#e8e8e8; -fx-table-cell-border-color:#f0f0f0;">
                    <columns>
                        <TableColumn fx:id="colMonth"         text="Month"          prefWidth="110"/>
                        <TableColumn fx:id="colTotalRequests" text="Total Requests"  prefWidth="110"/>
                        <TableColumn fx:id="colApproved"      text="Approved"        prefWidth="90"/>
                        <TableColumn fx:id="colRejected"      text="Rejected"        prefWidth="80"/>
                        <TableColumn fx:id="colPending"       text="Pending"         prefWidth="80"/>
                        <TableColumn fx:id="colMonthVisitors" text="Total Visitors"  prefWidth="110"/>
                        <TableColumn fx:id="colAvgDuration"   text="Avg Duration"    prefWidth="100"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                    <placeholder>
                        <Label text="No monthly records found."
                               style="-fx-text-fill:#AAA; -fx-font-size:13px;"/>
                    </placeholder>
                </TableView>
            </VBox>

        </VBox>
    </center>

</BorderPane>
