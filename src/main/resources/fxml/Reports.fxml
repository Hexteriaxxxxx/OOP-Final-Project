<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="main.controllers.ReportsController"
            style="-fx-background-color: #f9fafb;">

    <!-- ===== SIDEBAR ===== -->
    <left>
        <VBox prefWidth="160" style="-fx-background-color: #8B0000;">

            <!-- Logo -->
            <VBox style="-fx-padding: 14 12 14 12; -fx-border-color: rgba(255,255,255,0.15); -fx-border-width: 0 0 1 0;">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="🛡" style="-fx-text-fill: white; -fx-font-size: 18px;"/>
                    <VBox>
                        <Label text="Pass Slip" style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                        <Label text="Issuance System" style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-size: 10px;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Nav Items -->
            <VBox VBox.vgrow="ALWAYS" style="-fx-padding: 6 0 0 0;">
                <Button text="  ⊞  Dashboard" maxWidth="Infinity" onAction="#handleDashboard"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 12.5px; -fx-alignment: CENTER_LEFT; -fx-padding: 10 12 10 12; -fx-border-width: 0; -fx-cursor: hand;"/>
                <Button text="  📋  Pass Slip Issuance" maxWidth="Infinity" onAction="#handlePassSlip"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 12.5px; -fx-alignment: CENTER_LEFT; -fx-padding: 10 12 10 12; -fx-border-width: 0; -fx-cursor: hand;"/>
                <Button text="  👤  Visitor Module" maxWidth="Infinity" onAction="#handleVisitor"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 12.5px; -fx-alignment: CENTER_LEFT; -fx-padding: 10 12 10 12; -fx-border-width: 0; -fx-cursor: hand;"/>
                <Button text="  📊  Reports" maxWidth="Infinity"
                        style="-fx-background-color: rgba(255,255,255,0.18); -fx-text-fill: white; -fx-font-size: 12.5px; -fx-alignment: CENTER_LEFT; -fx-padding: 10 12 10 12; -fx-border-width: 0; -fx-cursor: hand;"/>
                <Button text="  👥  User Management" maxWidth="Infinity" onAction="#handleUserManagement"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 12.5px; -fx-alignment: CENTER_LEFT; -fx-padding: 10 12 10 12; -fx-border-width: 0; -fx-cursor: hand;"/>
            </VBox>

            <!-- Footer -->
            <VBox style="-fx-padding: 12 12 12 12; -fx-border-color: rgba(255,255,255,0.15); -fx-border-width: 1 0 0 0;">
                <Label fx:id="lblLoggedInUser" text="Admin" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                <Label fx:id="lblLoggedInRole" text="Admin" style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 11px;"/>
                <Button text="↪  Logout" maxWidth="Infinity" onAction="#handleLogout"
                        style="-fx-background-color: rgba(255,255,255,0.12); -fx-text-fill: white; -fx-font-size: 12px; -fx-padding: 6 10 6 10; -fx-background-radius: 6; -fx-border-width: 0; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>
            </VBox>
        </VBox>
    </left>

    <!-- ===== MAIN CONTENT ===== -->
    <center>
        <VBox style="-fx-background-color: white;">

            <!-- Top Bar -->
            <HBox alignment="CENTER_LEFT"
                  style="-fx-padding: 14 20 12 20; -fx-border-color: #e8e8e8; -fx-border-width: 0 0 1 0; -fx-background-color: white;">
                <VBox HBox.hgrow="ALWAYS">
                    <Label text="Reports" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;"/>
                    <Label text="View daily and monthly activity logs" style="-fx-font-size: 12px; -fx-text-fill: #888;"/>
                </VBox>
                <Label text="🔔" style="-fx-font-size: 18px; -fx-text-fill: #888;"/>
            </HBox>

            <!-- Stat Cards -->
            <HBox spacing="12" style="-fx-padding: 14 20 0 20; -fx-background-color: white;">

                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #f8f8f8; -fx-background-radius: 10; -fx-padding: 12 14 12 14; -fx-border-color: #ececec; -fx-border-radius: 10; -fx-border-width: 1;">
                    <HBox alignment="CENTER_LEFT">
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="Total This Month" style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
                            <Label fx:id="lblTotalMonth" text="0" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;"/>
                        </VBox>
                        <Label text="📄" style="-fx-font-size: 22px; -fx-text-fill: #ccc;"/>
                    </HBox>
                </VBox>

                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #f8f8f8; -fx-background-radius: 10; -fx-padding: 12 14 12 14; -fx-border-color: #ececec; -fx-border-radius: 10; -fx-border-width: 1;">
                    <HBox alignment="CENTER_LEFT">
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="Approved Rate" style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
                            <Label fx:id="lblApprovedRate" text="0%" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1D9E75;"/>
                        </VBox>
                        <Label text="📈" style="-fx-font-size: 22px; -fx-text-fill: #1D9E75;"/>
                    </HBox>
                </VBox>

                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #f8f8f8; -fx-background-radius: 10; -fx-padding: 12 14 12 14; -fx-border-color: #ececec; -fx-border-radius: 10; -fx-border-width: 1;">
                    <HBox alignment="CENTER_LEFT">
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="Avg Duration" style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
                            <Label fx:id="lblAvgDuration" text="—" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #185FA5;"/>
                        </VBox>
                        <Label text="🕐" style="-fx-font-size: 22px; -fx-text-fill: #185FA5;"/>
                    </HBox>
                </VBox>

                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #f8f8f8; -fx-background-radius: 10; -fx-padding: 12 14 12 14; -fx-border-color: #ececec; -fx-border-radius: 10; -fx-border-width: 1;">
                    <HBox alignment="CENTER_LEFT">
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="Total Visitors" style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
                            <Label fx:id="lblTotalVisitors" text="0" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #BA7517;"/>
                        </VBox>
                        <Label text="👥" style="-fx-font-size: 22px; -fx-text-fill: #BA7517;"/>
                    </HBox>
                </VBox>

            </HBox>

            <!-- Tabs + Export Button -->
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 14 20 10 20; -fx-background-color: white;">
                <HBox spacing="6" HBox.hgrow="ALWAYS">
                    <ToggleButton fx:id="btnDailyLogs" text="Daily Logs" selected="true"
                                  onAction="#switchToDaily"
                                  style="-fx-background-color: #8B0000; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 6 18 6 18; -fx-background-radius: 20; -fx-border-width: 0; -fx-cursor: hand;"/>
                    <ToggleButton fx:id="btnMonthlyLogs" text="Monthly Logs"
                                  onAction="#switchToMonthly"
                                  style="-fx-background-color: white; -fx-text-fill: #555; -fx-font-size: 13px; -fx-padding: 6 18 6 18; -fx-background-radius: 20; -fx-border-color: #ddd; -fx-border-radius: 20; -fx-border-width: 1; -fx-cursor: hand;"/>
                </HBox>
                <Button text="⬇  Export Report" onAction="#handleExport"
                        style="-fx-background-color: #1D9E75; -fx-text-fill: white; -fx-font-size: 12.5px; -fx-padding: 7 16 7 16; -fx-background-radius: 20; -fx-border-width: 0; -fx-cursor: hand;"/>
            </HBox>

            <!-- ===== DAILY LOGS SECTION ===== -->
            <VBox fx:id="dailySection" VBox.vgrow="ALWAYS" spacing="8"
                  style="-fx-padding: 0 20 20 20;">

                <!-- Search + Filter -->
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <TextField fx:id="searchField"
                               promptText="🔍  Search by name, ID, or department..."
                               onKeyReleased="#handleSearch"
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 7 12 7 12; -fx-font-size: 12.5px;"/>
                    <ComboBox fx:id="filterStatus" promptText="Filter" onAction="#handleFilter"
                              style="-fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: #ddd; -fx-background-color: white; -fx-font-size: 12.5px; -fx-pref-width: 110px;"/>
                </HBox>

                <!-- Daily Table -->
                <TableView fx:id="dailyTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: white; -fx-border-color: #e8e8e8; -fx-table-cell-border-color: #f0f0f0;">
                    <columns>
                        <TableColumn fx:id="colRequestId"  text="Request ID"    prefWidth="90"/>
                        <TableColumn fx:id="colDate"       text="Date"          prefWidth="90"/>
                        <TableColumn fx:id="colEmpName"    text="Employee Name" prefWidth="120"/>
                        <TableColumn fx:id="colDepartment" text="Department"    prefWidth="110"/>
                        <TableColumn fx:id="colPurpose"    text="Purpose"       prefWidth="130"/>
                        <TableColumn fx:id="colTimeOut"    text="Time Out"      prefWidth="80"/>
                        <TableColumn fx:id="colTimeIn"     text="Time In"       prefWidth="80"/>
                        <TableColumn fx:id="colDuration"   text="Duration"      prefWidth="70"/>
                        <TableColumn fx:id="colStatus"     text="Status"        prefWidth="90"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>

            <!-- ===== MONTHLY LOGS SECTION ===== -->
            <VBox fx:id="monthlySection" VBox.vgrow="ALWAYS"
                  visible="false" managed="false"
                  style="-fx-padding: 0 20 20 20;">

                <!-- Monthly Table -->
                <TableView fx:id="monthlyTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: white; -fx-border-color: #e8e8e8; -fx-table-cell-border-color: #f0f0f0;">
                    <columns>
                        <TableColumn fx:id="colMonth"         text="Month"          prefWidth="110"/>
                        <TableColumn fx:id="colTotalRequests" text="Total Requests" prefWidth="110"/>
                        <TableColumn fx:id="colApproved"      text="Approved"       prefWidth="90"/>
                        <TableColumn fx:id="colRejected"      text="Rejected"       prefWidth="80"/>
                        <TableColumn fx:id="colPending"       text="Pending"        prefWidth="80"/>
                        <TableColumn fx:id="colMonthVisitors" text="Total Visitors" prefWidth="110"/>
                        <TableColumn fx:id="colAvgDuration"   text="Avg Duration"   prefWidth="100"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>

        </VBox>
    </center>
</BorderPane>
