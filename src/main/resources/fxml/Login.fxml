<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="main.controllers.LoginController"
           prefWidth="1280" prefHeight="720">

    <!-- Background: Dark Red Gradient -->
    <Pane>
        <style>
            -fx-background-color: linear-gradient(to bottom right, #600000, #900000, #800000);
        </style>
    </Pane>

    <!-- Center Card -->
    <VBox alignment="CENTER" spacing="0">

        <!-- Logo + Title above card -->
        <VBox alignment="CENTER" spacing="8" style="-fx-padding: 0 0 20 0;">

            <!-- Shield Icon Circle -->
            <StackPane>
                <Circle radius="36" fill="white" opacity="0.15"/>
                <Circle radius="32" fill="white"/>
                <!-- Shield label as text fallback -->
                <Label text="🛡" style="-fx-font-size: 28px;"/>
            </StackPane>

            <Label text="Pass Slip Issuance"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-family: 'Segoe UI';"/>
            <Label text="Secure Login Portal"
                   style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.75); -fx-font-family: 'Segoe UI';"/>
        </VBox>

        <!-- White Card -->
        <VBox alignment="CENTER" spacing="16"
              style="-fx-background-color: white;
                     -fx-background-radius: 16;
                     -fx-padding: 32 40 28 40;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 24, 0, 0, 6);"
              maxWidth="340" minWidth="320">

            <!-- Staff / Admin Toggle -->
            <HBox alignment="CENTER" spacing="0"
                  style="-fx-background-color: #f0f0f0; -fx-background-radius: 8; -fx-padding: 4;">

                <Button fx:id="staffTab" text="Staff"
                        onAction="#handleStaffTab"
                        style="-fx-background-color: #8B0000; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-font-size: 13px;
                               -fx-background-radius: 6; -fx-padding: 8 36;"
                        maxWidth="Infinity" HBox.hgrow="ALWAYS"/>

                <Button fx:id="adminTab" text="Admin"
                        onAction="#handleAdminTab"
                        style="-fx-background-color: transparent; -fx-text-fill: #888;
                               -fx-font-size: 13px; -fx-background-radius: 6;
                               -fx-padding: 8 36;"
                        maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- Username Field -->
            <VBox spacing="5">
                <Label text="Username"
                       style="-fx-font-size: 13px; -fx-font-weight: bold;
                              -fx-text-fill: #333; -fx-font-family: 'Segoe UI';"/>
                <TextField fx:id="usernameField"
                           promptText="Enter your username"
                           style="-fx-background-color: #f9f9f9;
                                  -fx-border-color: #ddd; -fx-border-radius: 8;
                                  -fx-background-radius: 8; -fx-padding: 10 12;
                                  -fx-font-size: 13px; -fx-font-family: 'Segoe UI';"/>
            </VBox>

            <!-- Password Field -->
            <VBox spacing="5">
                <Label text="Password"
                       style="-fx-font-size: 13px; -fx-font-weight: bold;
                              -fx-text-fill: #333; -fx-font-family: 'Segoe UI';"/>
                <PasswordField fx:id="passwordField"
                               promptText="Enter your password"
                               style="-fx-background-color: #f9f9f9;
                                      -fx-border-color: #ddd; -fx-border-radius: 8;
                                      -fx-background-radius: 8; -fx-padding: 10 12;
                                      -fx-font-size: 13px; -fx-font-family: 'Segoe UI';"/>
            </VBox>

            <!-- Remember Me + Forgot Password -->
            <HBox alignment="CENTER_LEFT" spacing="0">
                <CheckBox fx:id="rememberMe" text="Remember me"
                          style="-fx-font-size: 12px; -fx-text-fill: #555;
                                 -fx-font-family: 'Segoe UI';"
                          HBox.hgrow="ALWAYS"/>
                <Hyperlink text="Forgot Password?"
                           onAction="#handleForgotPassword"
                           style="-fx-font-size: 12px; -fx-text-fill: #555;
                                  -fx-border-color: transparent;
                                  -fx-font-family: 'Segoe UI';"/>
            </HBox>

            <!-- Sign In Button -->
            <Button text="Sign In"
                    onAction="#handleLogin"
                    maxWidth="Infinity"
                    style="-fx-background-color: #8B0000; -fx-text-fill: white;
                           -fx-font-size: 14px; -fx-font-weight: bold;
                           -fx-background-radius: 8; -fx-padding: 12;
                           -fx-cursor: hand; -fx-font-family: 'Segoe UI';"/>

            <!-- Sign Up Link -->
            <HBox alignment="CENTER" spacing="4">
                <Label text="Don't have an account?"
                       style="-fx-font-size: 12px; -fx-text-fill: #666;
                              -fx-font-family: 'Segoe UI';"/>
                <Hyperlink text="Sign Up"
                           onAction="#handleSignUp"
                           style="-fx-font-size: 12px; -fx-text-fill: #8B0000;
                                  -fx-font-weight: bold; -fx-border-color: transparent;
                                  -fx-font-family: 'Segoe UI';"/>
            </HBox>

            <!-- Staff Portal Label -->
            <Label text="Staff Portal"
                   style="-fx-font-size: 11px; -fx-text-fill: #aaa;
                          -fx-font-family: 'Segoe UI';"
                   alignment="CENTER" maxWidth="Infinity"/>

        </VBox>

        <!-- Footer -->
        <Label text="© 2026 Pass Slip Issuance System. All rights reserved."
               style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.6);
                      -fx-font-family: 'Segoe UI'; -fx-padding: 20 0 0 0;"/>

    </VBox>
</StackPane>
